  },
  "properties": {
    "repeat": {
      "default": false,
      "description": "Repeat the sequence until changed.",
      "title": "Repeat",
      "type": "boolean"
    },
    "random": {
      "default": false,
      "description": "Execute elements in a random order.",
      "title": "Random",
      "type": "boolean"
    },
    "sequence": {
      "description": "An array of sequence elements.",
      "items": {
        "$ref": "#/$defs/WledSequenceElement"
      },
      "title": "Sequence",
      "type": "array"
    }
  },
  "required": [
    "sequence"
  ],
  "title": "LedSequence",
  "type": "object"
}