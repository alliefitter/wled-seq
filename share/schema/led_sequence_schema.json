          "title": "Live"
        },
        "lor": {
          "anyOf": [
            {
              "maximum": 2,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Live data override mode: 0=off, 1=until live ends, 2=until reboot.",
          "title": "Lor"
        },
        "time": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set system time (Unix timestamp).",
          "title": "Time"
        },
        "mainseg": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Index of the main segment.",
          "title": "Mainseg"
        },
        "seg": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SegItem"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Array of segment objects.",
          "title": "Seg"
        }
