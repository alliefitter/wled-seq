        "rgrp": {
          "anyOf": [
            {
              "maximum": 255,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Receive group.",
          "title": "Rgrp"
        },
        "nn": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
