{
  "$defs": {
    "ColItem": {
      "maximum": 255,
      "minimum": 0,
      "title": "ColItem",
      "type": "integer"
    },
    "Nl": {
      "additionalProperties": false,
      "properties": {
        "on": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Turn nightlight on or off.",
          "title": "On"
        },
        "dur": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Duration in minutes.",
          "title": "Dur"
        },
        "mode": {
          "anyOf": [
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Mode: 0=instant, 1=fade, 2=color fade, 3=sunrise.",
          "title": "Mode"
        },
        "tbri": {
          "anyOf": [
            {
              "maximum": 255,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Target brightness at the end.",
          "title": "Tbri"
        }
      },
      "title": "Nl",
      "type": "object"
    },
    "On": {
      "enum": [
        true,
        false,
        "t",
        "f"
      ],
      "title": "On"
    },
    "SegItem": {
