        "psave": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Save current state to given preset ID.",
          "title": "Psave"
        },
        "nl": {
          "anyOf": [
            {
              "$ref": "#/$defs/Nl"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Nightlight configuration."
        },
        "udpn": {
          "anyOf": [
            {
              "$ref": "#/$defs/Udpn"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "UDP sync configuration."
        },
        "live": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
